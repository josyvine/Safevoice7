<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Header Panel with Close Action Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Circle Invite QR Code"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Close Dialog" />
    </RelativeLayout>

    <!-- Subheader for Circle Name Display -->
    <TextView
        android:id="@+id/tvCircleName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Circle: Loading..."
        android:textSize="15sp"
        android:textColor="#00796B"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Card Container for QR Code Image -->
    <androidx.cardview.widget.CardView
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:visibility="invisible"
            android:contentDescription="Setup QR Code" />
    </GridCardView>
    </com.google.android.material.card.MaterialCardView> -->
    <!-- Custom card containers fallback for older platforms -->
    </LinearLayout>

    <!-- Description Note -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Family members or friends can scan this QR code on their device to automatically join your private safety circle."
        android:textSize="13sp"
        android:textColor="#757575"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Sharing Trigger Button -->
    <Button
        android:id="@+id/btnShareQr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Setup QR Code"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>