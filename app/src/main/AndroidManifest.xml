<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="34"
        tools:overrideLibrary="com.google.android.gms.ads_identifier" />

    <!-- Core Permissions for Safe Voice -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- CRITICAL (Bypasses Android 10+ background blocks to solve Glitch 1) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Permissions needed for background alert monitoring and WebRTC signaling -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Location Permissions for Safe Voice -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Camera Permissions for Safe Voice QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Declare hardware features Safe Voice uses -->
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.microphone" android:required="true" />

    <application
        android:name=".SafeVoiceApplication"
        android:allowBackup="true"
        android:icon="@drawable/safevoice"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <!-- DisclaimerActivity is the LAUNCHER, ensuring user agrees to terms first -->
        <activity
            android:name=".DisclaimerActivity"
            android:exported="true"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- The main app interface, launched after the disclaimer is accepted -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Onboarding role selection on first-time application launch -->
        <activity
            android:name=".RoleSelectionActivity"
            android:label="Select Role"
            android:exported="false" />

        <!-- User safety circle dynamic configuration setup workspace -->
        <activity
            android:name=".CircleSetupActivity"
            android:label="Set Up Circle"
            android:exported="false" />

        <!-- The QR scanning portal for family members to join existing circles -->
        <activity
            android:name=".CircleJoinQrScanActivity"
            android:label="Scan Circle QR"
            android:exported="false" />

        <!-- The activity declaration for the central login gateway screen -->
        <activity
            android:name=".LoginActivity"
            android:label="Sign In"
            android:exported="false" />
            
        <!-- The full-screen activity for receiving emergency alerts -->
        <activity
            android:name=".EmergencyPopupActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- Full-screen WebRTC calling screen featuring mute, speaker, and timer states -->
        <activity
            android:name=".webrtc.WebRTCCallActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:theme="@style/AppTheme.NoActionBar" />

        <!-- The "Always Listening" background service -->
        <service
            android:name=".services.VoiceRecognitionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <!-- The service that handles sending alerts after a trigger -->
        <service
            android:name=".services.EmergencyHandlerService"
            android:enabled="true"
            android:exported="false" />
            
        <!-- The service for receiving Firebase Cloud Messaging alerts -->
        <service
            android:name=".services.FirebaseAlertService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Secure File Provider declaration needed for outward image sharing -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.safevoice.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <!-- CRITICAL: This disables the default Firebase initializer,
             allowing our app to load the configuration dynamically at runtime. -->
        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="${applicationId}.firebaseinitprovider"
            tools:node="remove" />

    </application>

</manifest>